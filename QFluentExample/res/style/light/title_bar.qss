FluentTitleBar[bar-active=true] {
    background-color: transparent;
}

FluentTitleBar[bar-active=false] {
    background-color: transparent;
}


/* Title label */

FluentTitleBar>QLabel#win-title-label {
    padding: 0;
    border: none;
    color: #131313;
    background-color: transparent;
    min-height: 28px;
}


/* System buttons */

FluentTitleBar>QAbstractButton[system-button=true] {
    min-width: 40px;
    border: none;
    padding: 0;
    background-color: transparent;
    outline: none;
}

FluentTitleBar>QAbstractButton#back-button:hover {
    background-color: rgba(0, 0, 0, 10);
    border-radius: 5px;
}

FluentTitleBar>QAbstractButton#back-button:pressed {
    background-color: rgba(0, 0, 0, 7);
    border-radius: 5px;
}

FluentTitleBar>QAbstractButton#theme-button:hover,
FluentTitleBar>QAbstractButton#theme-button:pressed {
    background-color: rgba(0, 0, 0, 15%);
}

FluentTitleBar>QAbstractButton#min-button:hover,
FluentTitleBar>QAbstractButton#min-button:pressed {
    background-color: rgba(0, 0, 0, 15%);
}


FluentTitleBar>QAbstractButton#max-button:hover,
FluentTitleBar>QAbstractButton#max-button:pressed {
    background-color: rgba(0, 0, 0, 15%);
}

FluentTitleBar>QAbstractButton#close-button:hover,
FluentTitleBar>QAbstractButton#close-button:pressed {
    background-color: #e81123;
}


/* Icon button */

FluentTitleBar>QAbstractButton#icon-button {
    border: none;
    padding: 0;
    background-color: transparent;
}
